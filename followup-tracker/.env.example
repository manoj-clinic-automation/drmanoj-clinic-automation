# .env.example — WABA send layer for the Follow-Up Tracker
# Copy to ".env" (or set as real environment variables) and fill MYOP_AUTH_TOKEN.
# NEVER commit the real token. On the VPS, set these as environment variables.

MYOP_BASE_URL=https://publicapi.myoperator.co
MYOP_COMPANY_ID=68384350414b9847
MYOP_PHONE_NUMBER_ID=1090067637530949
MYOP_WABA_ID=2101222617483538
MYOP_COUNTRY_CODE=91

# SECRET — the "Authentication" value from panel:
#   APIs & Webhooks -> Developer API -> WhatsApp APIs -> Authentication (eye -> copy)
# Paste it here locally for testing; on the VPS set it as a real env var, not a file.
MYOP_AUTH_TOKEN=PASTE_THE_WHATSAPP_APIS_AUTHENTICATION_VALUE_HERE

# Template body-variable format. Confirm with waba_probe.py, then leave it.
# options: var_n (default) | varn | numeric | list
WABA_TEMPLATE_BODY_FORMAT=var_n

# Safety: while testing, ONLY these numbers can ever receive a message.
# Comma-separated 10-digit numbers. LEAVE THIS SET until you go live to all patients.
WABA_TEST_ALLOWLIST=9837046634,9837114044,9389559274,8650108080,9045284080

# Pause-and-confirm ceiling. Eligible recipients above this halt the run.
WABA_DAILY_CAP=100
