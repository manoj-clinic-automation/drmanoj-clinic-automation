# ============================================================
# Dr Manoj Clinic Automation — .gitignore
# CODE ONLY repo. Secrets and patient data must NEVER be committed.
# When in doubt, this file errs on the side of blocking.
# ============================================================

# ---- SECRETS: environment files ----
.env
.env.*
*.env
# (allow the safe templates only)
!*.env.example
!.env.example

# ---- SECRETS: keys / credentials (service-account JSON, tokens, certs) ----
# Block ALL .json by default so a key file can never slip in.
*.json
# allow only clearly-safe example/template json
!*.example.json
*.pem
*.key
*.p12
*.pfx
*-key.*
*credentials*
*secret*
*token*

# ---- PATIENT DATA: exports, mirrors, logs, recordings ----
*.csv
*.tsv
*.xlsx
*.xls
*.jsonl
*.mp3
*.wav
*.vcf
wa_logs/
recordings/
exports/
uploads/

# ---- PYTHON runtime / build junk ----
venv/
.venv/
env/
ENV/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/

# ---- OS / editor noise ----
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# ---- Logs ----
*.log
