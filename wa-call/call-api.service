[Unit]
Description=MyOperator OBD click-to-call relay for the dashboard (Flask via gunicorn)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/wa
ExecStart=/root/wa/venv/bin/gunicorn -w 1 -b 127.0.0.1:8097 --timeout 60 call_api:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
