# wa_receiver configuration — copy to ".env" on the VPS and fill in.
# Never commit or share real values.

# The Clinic Callback Tracker spreadsheet id (same sheet the dashboard reads):
WA_SHEET_ID=1USjArkqIdrE9hIqerghms76STatM5XTbSW_a9I3klo0

# Full path to the patient-mirror service-account JSON, AFTER you copy it to the VPS:
WA_SA_KEY=/home/USERNAME/wa/patient-mirror-key.json

# Sheet tab to append to (leave as is):
WA_TAB=WA_Inbox

# A long random password you invent — it goes in the webhook URL as ?key=...
# so strangers can't post fake messages. Example: 40+ random letters/numbers.
WA_WEBHOOK_SECRET=PUT_A_LONG_RANDOM_STRING_HERE

# Networking (leave as is unless told otherwise):
WA_PORT=8095
WA_HOST=127.0.0.1

# Where raw message copies are kept on the VPS (safety net):
WA_RAW_LOG_DIR=/home/USERNAME/wa/wa_logs
